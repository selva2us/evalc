# Copy this file to .env and fill in real values. Never commit .env.

SECRET_KEY=change-me-to-a-random-string
FLASK_ENV=development

# Required: your Anthropic API key
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# Optional overrides
ANTHROPIC_MODEL=claude-sonnet-5
ANTHROPIC_MAX_TOKENS=8000

# Optional: defaults to a local SQLite file under instance/
DATABASE_URL=sqlite:///instance/curriculum.db

# --- AI Pipeline (elluval_pipeline) settings -----------------------------
# Required by the /pipeline routes: submitting a skeleton and uploading
# generated page content to your curriculum backend.
BASE_URL=https://dev.elluval.com
API_TOKEN=your-bearer-token
# Optional: path to a file containing the session cookie string, if your
# backend also needs one alongside the bearer token.
API_COOKIE_FILE=cookies.txt

# Optional overrides for the pipeline
PAGES_PER_CHAPTER=6
MODULES_PER_PILLAR=3
SKELETON_MODEL=claude-sonnet-4-6
CONTENT_MODEL=claude-sonnet-4-6
